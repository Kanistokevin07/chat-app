{
  "compilerOptions": {

    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,
    "allowSyntheticDefaultImports": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "baseUrl": ".",

    "paths": {
      "@/*": [
        "src/*"
      ]
    }

  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}